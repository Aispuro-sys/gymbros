{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "exercises-dataset/**", "prisma/**"]
      }
    }
  ],
  "rewrites": [
    { "source": "/exercises-dataset/(.*)", "destination": "/src/server.js" },
    { "source": "/(.*)", "destination": "/src/server.js" }
  ]
}
