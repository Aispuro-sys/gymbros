{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**", "exercises-dataset/**", "prisma/**"]
      }
    }
  ],
  "routes": [
    { "src": "/exercises-dataset/(.*)", "dest": "/exercises-dataset/$1" },
    { "src": "/api/(.*)", "dest": "/src/server.js" },
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)", "dest": "/public/js/$1" },
    { "src": "/(.*)", "dest": "/src/server.js" }
  ]
}
