generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  password     String
  phone        String?
  age          Int?
  height_cm    Float?
  weight_kg    Float?
  goal         String?  @default("MAINTENANCE")
  body_type    String?  
  gender       String?  @default("M")
  role         String   @default("NORMAL")
  bio          String?
  profile_photo String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  macros_logs      MacrosDailyLog[]
  routines         Routine[]
  progress_photos  ProgressPhoto[]
  supplements      SupplementMed[]
  team_memberships TeamMember[]
  owned_teams      Team[]
  shared_routines  TeamRoutine[]
  team_posts       TeamPost[]
  exercise_logs    ExerciseLog[]
  meals            Meal[]
  community_posts  CommunityPost[]
  community_replies CommunityReply[]
  community_reactions CommunityReaction[]
  shopping_lists   ShoppingList[]

  @@map("users")
}

model MacrosDailyLog {
  id         String   @id @default(uuid())
  user_id    String
  date       DateTime
  calories   Int      @default(0)
  protein_g  Int      @default(0)
  carbs_g    Int      @default(0)
  fats_g     Int      @default(0)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("macros_daily_log")
}

model Meal {
  id         String   @id @default(uuid())
  user_id    String
  name       String
  meal_type  String   @default("SNACK")
  calories   Int      @default(0)
  protein_g  Int      @default(0)
  carbs_g    Int      @default(0)
  fats_g     Int      @default(0)
  photo_url  String?
  confirmed  Boolean  @default(false)
  date       DateTime @default(now())
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("meals")
}

model Routine {
  id           String   @id @default(uuid())
  user_id      String
  name         String
  ai_generated Boolean  @default(false)
  ai_prompt    String?
  day_of_week  Int?     
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  user           User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  exercises      Exercise[]
  team_routines  TeamRoutine[]

  @@map("routines")
}

model Exercise {
  id                 String   @id @default(uuid())
  routine_id         String
  name               String
  sets               Int      @default(3)
  reps               String   @default("8-12")
  rest_seconds       Int      @default(90)
  order_index        Int      @default(0)
  exercise_dataset_id String?
  created_at         DateTime @default(now())

  routine Routine @relation(fields: [routine_id], references: [id], onDelete: Cascade)
  logs       ExerciseLog[]

  @@map("exercises")
}

model ExerciseLog {
  id          String   @id @default(uuid())
  user_id     String
  exercise_id String
  routine_id  String
  completed   Boolean  @default(true)
  date        DateTime @default(now())

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exercise_id], references: [id], onDelete: Cascade)

  @@unique([user_id, exercise_id, date])
  @@map("exercise_logs")
}

model ProgressPhoto {
  id            String   @id @default(uuid())
  user_id       String
  photo_url     String
  weight_logged Float?
  date          DateTime @default(now())
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("progress_photos")
}

model SupplementMed {
  id            String   @id @default(uuid())
  user_id       String
  name          String
  dosage        String
  time_of_day   String   @default("MORNING")
  is_medication Boolean  @default(false)
  created_at    DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("supplements_meds")
}

model Team {
  id           String   @id @default(uuid())
  name         String
  admin_id     String
  invite_code  String   @unique
  created_at   DateTime @default(now())

  admin          User          @relation(fields: [admin_id], references: [id], onDelete: Cascade)
  members        TeamMember[]
  shared_routines TeamRoutine[]
  posts          TeamPost[]

  @@map("teams")
}

model TeamMember {
  id      String @id @default(uuid())
  team_id String
  user_id String
  role    String @default("MEMBER")

  team Team @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([team_id, user_id])
  @@map("team_members")
}

model TeamRoutine {
  id         String   @id @default(uuid())
  team_id    String
  routine_id String
  shared_by  String
  shared_at  DateTime @default(now())

  team    Team    @relation(fields: [team_id], references: [id], onDelete: Cascade)
  routine Routine @relation(fields: [routine_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [shared_by], references: [id], onDelete: Cascade)

  @@map("team_routines")
}

model TeamPost {
  id         String   @id @default(uuid())
  team_id    String
  user_id    String
  content    String
  post_type  String   @default("MESSAGE")
  routine_id String?
  created_at DateTime @default(now())

  team Team    @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("team_posts")
}

model Recipe {
  id          String   @id @default(uuid())
  name        String
  description String?
  image_url   String?
  calories    Int      @default(0)
  protein_g   Int      @default(0)
  carbs_g     Int      @default(0)
  fats_g      Int      @default(0)
  prep_time_min Int    @default(0)
  servings    Int      @default(1)
  ingredients String[]
  instructions String[]
  meal_type   String   @default("ANY")
  diet_tags   String[]
  source      String   @default("community")
  created_at  DateTime @default(now())

  @@map("recipes")
}

model CommunityPost {
  id          String   @id @default(uuid())
  user_id     String
  content     String
  media_url   String?
  media_type  String   @default("TEXT")
  routine_id  String?
  parent_id   String?
  created_at  DateTime @default(now())

  user       User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  replies    CommunityReply[]
  reactions  CommunityReaction[]

  @@map("community_posts")
}

model CommunityReply {
  id          String   @id @default(uuid())
  post_id     String
  user_id     String
  content     String
  media_url   String?
  created_at  DateTime @default(now())

  user       User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  postRef    CommunityPost     @relation(fields: [post_id], references: [id], onDelete: Cascade)
  reactions  CommunityReaction[]

  @@map("community_replies")
}

model CommunityReaction {
  id          String   @id @default(uuid())
  post_id     String?
  reply_id    String?
  user_id     String
  emoji       String
  created_at  DateTime @default(now())

  user   User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post   CommunityPost?   @relation(fields: [post_id], references: [id], onDelete: Cascade)
  reply  CommunityReply?  @relation(fields: [reply_id], references: [id], onDelete: Cascade)

  @@map("community_reactions")
}

model ShoppingList {
  id          String   @id @default(uuid())
  user_id     String
  name        String   @default("Lista de Supermercado")
  share_token String?  @unique
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user  User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  items ShoppingListItem[]

  @@map("shopping_lists")
}

model ShoppingListItem {
  id              String   @id @default(uuid())
  shopping_list_id String
  name            String
  quantity        String?
  checked         Boolean  @default(false)
  recipe_names    String[]
  order_index     Int      @default(0)

  shoppingList ShoppingList @relation(fields: [shopping_list_id], references: [id], onDelete: Cascade)

  @@map("shopping_list_items")
}
